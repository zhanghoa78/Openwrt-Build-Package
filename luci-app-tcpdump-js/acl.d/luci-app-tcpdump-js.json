{
    "luci-app-tcpdump-js": {
        "description": "Grant access to TCPDump JS RPC calls",
        "read": {
            "rpc": {
                "tcpdump": [ "status" ]
            }
        },
        "write": {
            "rpc": {
                "tcpdump": [ "start", "stop" ]
            }
        }
    }
}
