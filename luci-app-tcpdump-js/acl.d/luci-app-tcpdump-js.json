{
    "luci-app-tcpdump-js": {
        "description": "Grant access to TCPDump JS RPC calls",
        "read": {
            "rpc": {
                "luci.tcpdump": [ "status" ] 
            }
        },
        "write": {
            "rpc": {
                "luci.tcpdump": [ "start", "stop" ] 
            }
        }
    }
}
