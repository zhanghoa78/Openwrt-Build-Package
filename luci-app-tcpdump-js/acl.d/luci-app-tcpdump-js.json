{
    "luci-app-tcpdump-js": {
        "description": "Grant access to TCPDump JS RPC calls",
        "read": {
            "rpc": {
                "luci.tcpdump": [ "status" ]  // ✅ 正确：使用完整的 RPC 路径
            }
        },
        "write": {
            "rpc": {
                "luci.tcpdump": [ "start", "stop" ]  // ✅ 正确：使用完整的 RPC 路径
            }
        }
    }
}
